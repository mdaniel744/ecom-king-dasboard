# App Setup
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Database & BaaS)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Clerk Authentication (SaaS Hosted Auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase (server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Merchant Center (Merchant API) — shared service account credential.
# Per-store Merchant ID / data source ID live in the stores table (Settings page),
# since each store on this platform connects to its own Merchant Center account.
GOOGLE_MERCHANT_SERVICE_ACCOUNT_KEY=your-service-account-json-as-a-single-line-string

# DeepSeek (AI translation engine, shared across all stores' translation jobs)
DEEPSEEK_API_KEY=your-deepseek-api-key
